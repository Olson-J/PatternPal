# PatternPal Environment Configuration
# Copy this file to .env.local and fill in the values for local development

# Supabase Configuration (Database and File Storage)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
PATTERNPAL_DEFAULT_USER_ID=00000000-0000-0000-0000-000000000001

# OpenAI API Configuration (LLM Integration)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_OUTPUT_TOKENS=1600
OPENAI_TEMPERATURE=0.2
USE_REAL_LLM=true

# Cost and traffic guardrails
GENERATION_RATE_LIMIT_WINDOW_MS=60000
GENERATION_RATE_LIMIT_MAX_REQUESTS=10
GENERATION_DAILY_BUDGET_USD=2.00

# Trigger.dev Configuration (Background Jobs)
# fill out the following if you want to use the Trigger.dev background job worker for PDF generation. Otherwise, the app will use a simple in-process queue (not suitable for production).
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=
TRIGGER_PROJECT_REF=
USE_TRIGGER_WORKER=false

# Application Environment
NODE_ENV=development

# API Base URL (for development/production)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
